VITE_SUI_NETWORK=testnet

# Filled after `sui client publish` or `sui client upgrade` (see contracts/README.md).
VITE_AILURUS_PACKAGE_ID=
# First-published package ID — required for Seal encrypt/decrypt after in-place upgrades.
VITE_AILURUS_PACKAGE_ID_LEGACY=
VITE_AILURUS_PLATFORM_ID=
VITE_AILURUS_PROFILE_REGISTRY_ID=

# Testnet or mainnet USDC type used by the subscription PTB (see docs/TESTNET.md).
VITE_AILURUS_USDC_TYPE=

# Optional — Enoki zkLogin + sponsored transactions.
VITE_ENOKI_PUBLIC_API_KEY=
VITE_SPONSOR_WORKER_URL=
VITE_GOOGLE_CLIENT_ID=

# Walrus / swap / Seal (testnet defaults in docs/TESTNET.md).
VITE_WALRUS_WAL_TYPE=
VITE_WALRUS_UPLOAD_RELAY_URL=
VITE_CETUS_AGGREGATOR_ENDPOINT=
VITE_SEAL_KEY_SERVERS=
